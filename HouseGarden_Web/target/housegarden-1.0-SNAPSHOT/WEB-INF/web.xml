<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>HouseGarden Web Application</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Servlet: Productos -->
    <servlet>
        <servlet-name>ProductoServlet</servlet-name>
        <servlet-class>com.mycompany.housegarden.servlet.ProductoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductoServlet</servlet-name>
        <url-pattern>/productos</url-pattern>
    </servlet-mapping>

    <!-- Servlet: Clientes -->
    <servlet>
        <servlet-name>ClienteServlet</servlet-name>
        <servlet-class>com.mycompany.housegarden.servlet.ClienteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ClienteServlet</servlet-name>
        <url-pattern>/clientes</url-pattern>
    </servlet-mapping>

    <!-- Servlet: Proveedores -->
    <servlet>
        <servlet-name>ProveedorServlet</servlet-name>
        <servlet-class>com.mycompany.housegarden.servlet.ProveedorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProveedorServlet</servlet-name>
        <url-pattern>/proveedores</url-pattern>
    </servlet-mapping>

    <!-- Servlet: Ordenes -->
    <servlet>
        <servlet-name>OrdenServlet</servlet-name>
        <servlet-class>com.mycompany.housegarden.servlet.OrdenServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrdenServlet</servlet-name>
        <url-pattern>/ordenes</url-pattern>
    </servlet-mapping>

</web-app>
